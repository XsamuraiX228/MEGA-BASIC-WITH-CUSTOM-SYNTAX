#mode "ENGLISH"

:while
PRINT "Enter the Number"
INPUT N
LET I = 2
LET IS_PRIME = 1

:check_loop
IF N == 0 THEN END
IF I == N THEN GOTO result
LET REM = N - N / I * I
IF REM == 0 THEN IF IS_PRIME == 1 THEN GOTO not_prime
LET I = I + 1
GOTO check_loop

:not_prime
LET IS_PRIME = 0
GOTO result

:result
IF IS_PRIME == 1 THEN GOTO print_prime
IF IS_PRIME == 0 THEN GOTO print_not_prime

:print_prime
PRINT "Number is PRIME"
GOTO while

:print_not_prime
PRINT "Number is NOT prime"
GOTO while